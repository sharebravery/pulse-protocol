{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse.sharebravery.dev/schemas/publication-result/v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "publication-result/v1"
    },
    "publicationId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{7,127}$",
      "description": "Globally unique publication attempt identifier."
    },
    "contentId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{7,127}$",
      "description": "Stable identifier of the content being submitted or published."
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "description": "Time this publication result was recorded."
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "published",
        "failed"
      ],
      "description": "Current platform outcome for this publication attempt."
    },
    "content": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "article",
            "social_post"
          ],
          "description": "Kind of content submitted to the platform."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Human-readable content title."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000,
          "description": "Concise summary suitable for a status email."
        },
        "category": {
          "description": "Optional article or platform category.",
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "tags": {
          "description": "Optional distinct tags.",
          "maxItems": 10,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        },
        "metrics": {
          "description": "Optional compact content metrics used only for status reporting.",
          "type": "object",
          "properties": {
            "characterCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "sourceCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "hasCover": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "kind",
        "title",
        "summary"
      ],
      "additionalProperties": false,
      "description": "Compact metadata for the published or submitted content."
    },
    "destination": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "enum": [
            "blog",
            "x",
            "xhs",
            "wechat",
            "zhihu",
            "toutiao",
            "other"
          ],
          "description": "Destination platform."
        },
        "label": {
          "description": "Optional human-readable destination name.",
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "repository": {
          "description": "Optional GitHub repository in owner/name form.",
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$"
        },
        "path": {
          "description": "Optional repository or platform content path.",
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      },
      "required": [
        "platform"
      ],
      "additionalProperties": false,
      "description": "Platform and location receiving the content."
    },
    "submissionUrl": {
      "description": "Optional platform submission, pull request, or edit URL.",
      "anyOf": [
        {
          "type": "string",
          "format": "uri",
          "description": "Public HTTPS URL. HTTP, local, credential-bearing, and non-web URLs are not allowed."
        },
        {
          "type": "null"
        }
      ]
    },
    "publishedUrl": {
      "description": "Canonical public URL after successful publication.",
      "anyOf": [
        {
          "type": "string",
          "format": "uri",
          "description": "Public HTTPS URL. HTTP, local, credential-bearing, and non-web URLs are not allowed."
        },
        {
          "type": "null"
        }
      ]
    },
    "commitSha": {
      "description": "Optional exact Git commit associated with the platform submission.",
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "submittedAt": {
      "description": "Time the content was submitted to the destination.",
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "publishedAt": {
      "description": "Time the content became publicly available.",
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "error": {
      "type": "object",
      "properties": {
        "stage": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "description": "Operation stage that failed."
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "description": "Concise failure message."
        },
        "url": {
          "description": "Optional workflow, log, or platform URL.",
          "anyOf": [
            {
              "type": "string",
              "format": "uri",
              "description": "Public HTTPS URL. HTTP, local, credential-bearing, and non-web URLs are not allowed."
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "stage",
        "message"
      ],
      "additionalProperties": false,
      "description": "Failure details when publication does not complete."
    }
  },
  "required": [
    "schemaVersion",
    "publicationId",
    "contentId",
    "recordedAt",
    "status",
    "content",
    "destination"
  ],
  "additionalProperties": false,
  "title": "Pulse Publication Result v1",
  "description": "Compact outcome of submitting or publishing Pulse content to a destination platform. It is suitable for deterministic status delivery and does not contain the full content body."
}
