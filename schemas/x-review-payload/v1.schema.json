{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse.sharebravery.dev/schemas/x-review-payload/v1",
  "title": "Pulse X Review Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reviewId",
    "generatedAt",
    "timezone",
    "account",
    "operator",
    "event",
    "sources",
    "images",
    "candidates"
  ],
  "properties": {
    "schemaVersion": { "const": "x-review-payload/v1" },
    "reviewId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{7,127}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "timezone": { "const": "Asia/Hong_Kong" },
    "account": { "$ref": "#/$defs/accountRef" },
    "operator": { "$ref": "#/$defs/operatorRef" },
    "event": { "$ref": "#/$defs/event" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "images": {
      "type": "array",
      "maxItems": 2,
      "items": { "$ref": "#/$defs/imageRef" }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/candidate" }
    }
  },
  "$defs": {
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "accountRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "accountId"],
      "properties": {
        "platform": { "const": "x" },
        "accountId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
        "handle": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "operatorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "repo", "commit"],
      "properties": {
        "name": { "const": "pulse-x" },
        "repo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "commit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventTitle", "publishJudgment", "repeatReason", "primaryDomain"],
      "properties": {
        "eventTitle": { "type": "string", "minLength": 1, "maxLength": 180 },
        "publishJudgment": { "type": "string", "minLength": 1, "maxLength": 500 },
        "repeatReason": { "type": "string", "minLength": 1, "maxLength": 300 },
        "primaryDomain": { "type": "string", "minLength": 1, "maxLength": 80 },
        "relatedDomains": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "title", "url"],
      "properties": {
        "sourceId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$" },
        "title": { "type": "string", "minLength": 1, "maxLength": 300 },
        "url": { "$ref": "#/$defs/httpsUrl" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "kind": { "type": "string", "minLength": 1, "maxLength": 60 }
      }
    },
    "imageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["imageId", "url", "sourcePageUrl", "alt", "sourceName", "usage"],
      "properties": {
        "imageId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$" },
        "url": { "$ref": "#/$defs/httpsUrl" },
        "sourcePageUrl": { "$ref": "#/$defs/httpsUrl" },
        "alt": { "type": "string", "minLength": 1, "maxLength": 500 },
        "caption": { "type": "string", "maxLength": 500 },
        "sourceName": { "type": "string", "minLength": 1, "maxLength": 120 },
        "usage": { "enum": ["primary", "supporting"] }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "author", "publishedAt"],
      "properties": {
        "url": { "$ref": "#/$defs/httpsUrl" },
        "author": { "type": "string", "minLength": 1, "maxLength": 100 },
        "publishedAt": { "type": "string", "format": "date-time" }
      }
    },
    "postCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "kind", "label", "angle", "reason", "language", "sourceIds", "imageIds", "text"],
      "properties": {
        "candidateId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$" },
        "kind": { "const": "post" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "angle": { "type": "string", "minLength": 1, "maxLength": 120 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "language": { "const": "en" },
        "sourceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "imageIds": { "type": "array", "maxItems": 2, "uniqueItems": true, "items": { "type": "string" } },
        "text": { "type": "string", "minLength": 1, "maxLength": 280 }
      }
    },
    "replyCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "kind", "label", "angle", "reason", "language", "sourceIds", "imageIds", "text", "target"],
      "properties": {
        "candidateId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$" },
        "kind": { "const": "reply" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "angle": { "type": "string", "minLength": 1, "maxLength": 120 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "language": { "const": "en" },
        "sourceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "imageIds": { "type": "array", "maxItems": 2, "uniqueItems": true, "items": { "type": "string" } },
        "text": { "type": "string", "minLength": 1, "maxLength": 280 },
        "target": { "$ref": "#/$defs/target" }
      }
    },
    "quoteCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "kind", "label", "angle", "reason", "language", "sourceIds", "imageIds", "text", "target"],
      "properties": {
        "candidateId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$" },
        "kind": { "const": "quote" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "angle": { "type": "string", "minLength": 1, "maxLength": 120 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "language": { "const": "en" },
        "sourceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "imageIds": { "type": "array", "maxItems": 2, "uniqueItems": true, "items": { "type": "string" } },
        "text": { "type": "string", "minLength": 1, "maxLength": 280 },
        "target": { "$ref": "#/$defs/target" }
      }
    },
    "threadCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "kind", "label", "angle", "reason", "language", "sourceIds", "imageIds", "posts"],
      "properties": {
        "candidateId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$" },
        "kind": { "const": "thread" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "angle": { "type": "string", "minLength": 1, "maxLength": 120 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "language": { "const": "en" },
        "sourceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "imageIds": { "type": "array", "maxItems": 2, "uniqueItems": true, "items": { "type": "string" } },
        "posts": { "type": "array", "minItems": 2, "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 280 } }
      }
    },
    "articleCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "kind", "label", "angle", "reason", "language", "sourceIds", "imageIds", "title", "bodyMarkdown"],
      "properties": {
        "candidateId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$" },
        "kind": { "const": "article" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "angle": { "type": "string", "minLength": 1, "maxLength": 120 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "language": { "const": "en" },
        "sourceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "imageIds": { "type": "array", "maxItems": 2, "uniqueItems": true, "items": { "type": "string" } },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "bodyMarkdown": { "type": "string", "minLength": 1, "maxLength": 30000 }
      }
    },
    "candidate": {
      "oneOf": [
        { "$ref": "#/$defs/postCandidate" },
        { "$ref": "#/$defs/replyCandidate" },
        { "$ref": "#/$defs/quoteCandidate" },
        { "$ref": "#/$defs/threadCandidate" },
        { "$ref": "#/$defs/articleCandidate" }
      ]
    }
  }
}
